# --- 应用 ---
APP_ENV=development
APP_DEBUG=true

# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://mive:mive@localhost:5432/mive

# --- 管理员账号（首次启动自动创建）---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- LLM ---
# provider: anthropic / openai / qwen / deepseek / kimi / mimo / custom
# 快速验证 UI 流程用 mock 模式：LLM_PROVIDER=mock，LLM_API_KEY 随便填非空值
# model 和 api_key 为必填字段；base_url / api_format 可选（填了会覆盖 provider 内置默认值）
LLM_PROVIDER=anthropic

LLM_API_KEY=sk-...
LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=
# LLM_API_FORMAT=

LLM_MAX_RETRIES=
LLM_RPM=

# 副模型（SUB_LLM）— 判断/分类类简单调用走更便宜的副模型；空 key=不启用，回落主模型
# 想真正分离就把下面填上（指向更便宜的模型）
# SUB_LLM_PROVIDER 留空则复用 LLM_PROVIDER；可与主模型不同供应商（如主 mimo + 副 deepseek）
# model 和 api_key 为必填；base_url / api_format 可选（同样覆盖 provider 默认值）
SUB_LLM_PROVIDER=

SUB_LLM_API_KEY=
SUB_LLM_MODEL=
# SUB_LLM_BASE_URL=
# SUB_LLM_API_FORMAT=

SUB_LLM_MAX_INFLIGHT=5
SUB_LLM_RPM=

# --- ZEP ---
ZEP_ENABLED=false
ZEP_API_KEY=
ZEP_BASE_URL=

# --- Web Search ---
TAVILY_API_KEY=

# --- 并发控制 ---
# RateLimitGate 通过 LLM_RPM（节奏）+ LLM_MAX_INFLIGHT（在飞并发数上限）
# 双重准入统一管控所有 LLM 调用
# 可选：RateLimitGate 最大重试次数（默认 2，即首次 + 2 次 = 最多 3 次尝试）
# LLM_MAX_RETRIES=4
# 可选：LLM 速率门（每分钟最大请求数）。0 或不填 = 不限速
# LLM_RPM=50
# 可选：在飞请求数上限（已发出、正在等待/生成响应、未完成的请求数）。默认 5，<=0 视为不限制
LLM_MAX_INFLIGHT=5

# --- M8 Discord Bridge ---
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# --- Matterbridge Integration ---
# 桥接聊天平台（Discord、Telegram、Slack 等）到 MIVE 世界
# 设为 "true" 启用 Matterbridge 集成功能
MATTERBRIDGE_ENABLED=false

# --- Secret Encryption Key (AES-256-GCM, used to encrypt stored API keys / Matterbridge bindings) ---
SECRET_ENCRYPTION_KEY=

# --- Embedding (向量检索) ---
# 独立于 LLM 的 API Key，用于生成世界元素/角色的向量嵌入
EMBEDDING_API_KEY=
# OpenAI 兼容的 embedding API 地址（不含 /embeddings 后缀）
# EMBEDDING_BASE_URL=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# 可选：检索参数调优
# RETRIEVAL_TOP_K=10
# RETRIEVAL_BM25_TOP_K=20
# RETRIEVAL_VEC_TOP_K=20
# RETRIEVAL_RRF_K=60

# --- 记忆传播系统 ---
# 开启后角色的记忆会通过关系网络传播给关联角色（传闻记忆）
MEMORY_PROPAGATION_ENABLED=FALSE

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
